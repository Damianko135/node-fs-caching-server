{
  "name": "fs-caching-server",
  "version": "0.1.0",
  "description": "A caching HTTP server/proxy that stores data on the local filesystem",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fs-caching-server": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "clean": "rimraf dist",
    "test": "pnpm run build && tape tests/*.js",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Damianko135/node-fs-caching-server.git"
  },
  "keywords": [
    "fs",
    "caching",
    "proxy",
    "http",
    "typescript"
  ],
  "author": "Damian Korver <damiankorver@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Damianko135/node-fs-caching-server/issues"
  },
  "homepage": "https://github.com/Damianko135/node-fs-caching-server",
  "engines": {
    "node": ">=18.3.0"
  },
  "dependencies": {
    "access-log": "^0.4.1",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "rimraf": "^6.0.0",
    "tape": "^5.9.0"
  }
}
